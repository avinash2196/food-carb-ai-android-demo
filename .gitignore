# ── Build outputs ─────────────────────────────────────────────────────────────
.gradle/
build/
app/build/
captures/
out/

# ── Local configuration (never commit \u2014 contains SDK path) ─────────────────────
local.properties

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
*.hprof

# ── Android Studio / IntelliJ IDE files ──────────────────────────────────────
.idea/
*.iml
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml
.externalNativeBuild/
.cxx/

# ── Build artifacts ───────────────────────────────────────────────────────────
*.apk
*.aab
output.json

# ── Keystore / signing files (never commit private keys) ─────────────────────
*.jks
*.keystore

# ── Google Services ───────────────────────────────────────────────────────────
google-services.json

# ── Sensitive secrets \u2014 if you extract API keys to a separate properties file,
#    add it here so it is never committed:
# secrets.properties

# ── OS-specific files ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
